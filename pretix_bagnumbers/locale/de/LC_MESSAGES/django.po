# apps.py
msgid "Bag Numbers"
msgstr "Taschennummern"

msgid "Consecutive bag numbers with configurable number ranges per product. Numbers are unique per event, are released on cancellation, and are available in ticket printing and exports."
msgstr "Fortlaufende Taschennummern mit konfigurierbaren Nummernkreisen pro Produkt. Nummern sind pro Event eindeutig, werden bei Stornierung freigegeben und stehen beim Ticketdruck und in Exporten zur Verfügung."

# forms.py
msgid "Bag Number"
msgstr "Taschennummer"

msgid "Number range"
msgstr "Nummernkreis"

msgid "Leave empty if this product should not receive a bag number. Manage number ranges under Settings → Bag Numbers."
msgstr "Leer lassen, wenn dieses Produkt keine Taschennummer erhalten soll. Nummernkreise unter Einstellungen → Taschennummern verwalten."

msgid "End must not be less than start."
msgstr "Das Ende darf nicht kleiner als der Start sein."

msgid "This number range overlaps with '%(name)s' (%(start)s–%(end)s)."
msgstr "Dieser Nummernkreis überschneidet sich mit '%(name)s' (%(start)s–%(end)s)."

msgid "Number %(n)s is already assigned (order %(o)s)."
msgstr "Nummer %(n)s ist bereits vergeben (Bestellung %(o)s)."

# signals.py
msgid "Bag number"
msgstr "Taschennummer"

# views.py
msgid "Number range saved."
msgstr "Nummernkreis gespeichert."

msgid "The number range '%(name)s' cannot be deleted while numbers from it are still assigned."
msgstr "Der Nummernkreis '%(name)s' kann nicht gelöscht werden, solange Nummern daraus vergeben sind."

msgid "Number range deleted."
msgstr "Nummernkreis gelöscht."

msgid "The number range could not be deleted because numbers from it were assigned in the meantime."
msgstr "Der Nummernkreis konnte nicht gelöscht werden, da inzwischen Nummern daraus vergeben wurden."

msgid "Number changed."
msgstr "Nummer geändert."

# logentrytypes.py
msgid "Bag number {number} was assigned (position #{positionid})."
msgstr "Taschennummer {number} wurde vergeben (Position #{positionid})."

msgid "Bag number {number} was released (position #{positionid})."
msgstr "Taschennummer {number} wurde freigegeben (Position #{positionid})."

msgid "Bag number was manually changed from {old_number} to {number} (position #{positionid})."
msgstr "Taschennummer wurde manuell von {old_number} auf {number} geändert (Position #{positionid})."

# exporters.py
msgctxt "export_category"
msgid "1 Juki"
msgstr "1 Juki"

msgid "Participant Data"
msgstr "Teilnehmerdaten"

msgid "Excel export with one row per participant (order position with bag number). Contains order code, bag number, first and last name, all event questions, invoice address, e-mail, and phone number. Only paid and pending orders; sorted by bag number ascending. Choose between all number ranges on one sheet or one sheet per number range."
msgstr "Excel-Export mit einer Zeile pro Teilnehmer (Bestellposition mit Taschennummer). Enthält Bestell-Nummer, Taschennummer, Vor- und Nachname, alle Event-Fragen, Rechnungsadresse, E-Mail und Telefonnummer. Nur bezahlte und ausstehende Bestellungen; sortiert nach Taschennummer. Wählbar: alle Nummernkreise auf einem Tabellenblatt oder pro Nummernkreis ein eigenes."

msgid "Format"
msgstr "Format"

msgid "Excel – All number ranges on one sheet"
msgstr "Excel – Alle Nummernkreise auf einem Tabellenblatt"

msgid "Excel – One sheet per number range"
msgstr "Excel – Pro Nummernkreis ein eigenes Tabellenblatt"

